import java.io.FileWriter;
import java.io.IOException;

public class Quijote {
    public static void main(String[] args) {
        String fichero = "Quijote.txt";

        try (FileWriter fw = new FileWriter(fichero)) {
            String linea1 = "En un lugar de La Mancha,\n";
            for (int i = 0; i < linea1.length(); i++) {
                fw.write(linea1.charAt(i));
            }
            System.out.println("Linea 1 escrita.");
        } catch (IOException e) {
            System.out.println("Error en parte 1: " + e.getMessage());
        }

        try (FileWriter fw = new FileWriter(fichero, true)) {
            fw.write("de cuyo nombre no quiero acordarme");
            System.out.println("Linea 2 añadida con éxito.");
        } catch (IOException e) {
            System.out.println("Error en parte 2: " + e.getMessage());
        }
    }
}